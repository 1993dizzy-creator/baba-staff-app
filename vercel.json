{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/inventory/snapshot",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/cron/sales-sync",
      "schedule": "*/5 10-18 * * *"
    },
    {
      "path": "/api/cron/sales-sync-final",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/cron/sales-deductions",
      "schedule": "*/15 10-18 * * *"
    },
    {
      "path": "/api/cron/sales-deductions-final",
      "schedule": "5 20 * * *"
    }
  ]
}